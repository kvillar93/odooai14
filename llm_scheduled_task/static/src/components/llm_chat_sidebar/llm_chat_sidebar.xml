<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-inherit="llm_thread.LLMChatSidebar" t-inherit-mode="extension">
        <!-- Escritorio: anclaje estable (antes: t-if !isSmall; ahora useDesktopSidebar) -->
        <xpath
            expr="//div[hasclass('o_LLMChatSidebar_newChatWrap--desktop')]"
            position="before"
        >
            <div
                t-if="scheduledTaskCount > 0 and !llmChatView.isSidebarCollapsed"
                class="d-flex justify-content-center px-3 pt-3 pb-0"
            >
                <button
                    type="button"
                    class="btn btn-outline-secondary btn-sm rounded w-100"
                    t-on-click="_onClickViewScheduledTasks"
                >
                    <i class="fa fa-tasks me-2" />
                    <span>Ver tareas creadas</span>
                </button>
            </div>
        </xpath>
        <!-- Móvil / popup flotante: overlay -->
        <xpath
            expr="//div[hasclass('o_LLMChatSidebar_newChatWrap--overlay')]"
            position="before"
        >
            <div
                t-if="scheduledTaskCount > 0"
                class="d-flex justify-content-center px-3 pt-3 pb-0"
            >
                <button
                    type="button"
                    class="btn btn-outline-secondary btn-sm rounded w-100"
                    t-on-click="_onClickViewScheduledTasks"
                >
                    <i class="fa fa-tasks me-2" />
                    <span>Ver tareas creadas</span>
                </button>
            </div>
        </xpath>
    </t>
</templates>
