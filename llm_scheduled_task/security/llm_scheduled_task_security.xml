<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- ───────────────────────────────────────────────
         Grupos
    ─────────────────────────────────────────────── -->
    <record id="group_llm_task_user" model="res.groups">
        <field name="name">LLM Tareas: Usuario</field>
        <field name="category_id" ref="base.module_category_productivity"/>
        <field name="comment">Puede ver y ejecutar sus propias tareas programadas LLM.</field>
    </record>

    <record id="group_llm_task_manager" model="res.groups">
        <field name="name">LLM Tareas: Gestor</field>
        <field name="category_id" ref="base.module_category_productivity"/>
        <field name="implied_ids" eval="[(4, ref('group_llm_task_user'))]"/>
        <field name="comment">Puede gestionar todas las tareas programadas LLM de cualquier usuario.</field>
    </record>

    <!-- Gestores LLM (módulo llm) heredan permiso de tareas programadas -->
    <record id="llm.group_llm_manager" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('group_llm_task_user'))]"/>
    </record>

    <!-- ───────────────────────────────────────────────
         Reglas de acceso a registros
    ─────────────────────────────────────────────── -->
    <!-- Usuarios solo ven sus propias tareas -->
    <record id="rule_llm_task_own" model="ir.rule">
        <field name="name">LLM Tarea: solo propias (usuario)</field>
        <field name="model_id" ref="model_llm_scheduled_task"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_llm_task_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Gestores ven todas las tareas -->
    <record id="rule_llm_task_all" model="ir.rule">
        <field name="name">LLM Tarea: todas (gestor)</field>
        <field name="model_id" ref="model_llm_scheduled_task"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_llm_task_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Logs: usuarios solo ven los de sus propias tareas -->
    <record id="rule_llm_task_log_own" model="ir.rule">
        <field name="name">LLM Log Tarea: solo propias (usuario)</field>
        <field name="model_id" ref="model_llm_scheduled_task_log"/>
        <field name="domain_force">[('task_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_llm_task_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Gestores ven todos los logs -->
    <record id="rule_llm_task_log_all" model="ir.rule">
        <field name="name">LLM Log Tarea: todos (gestor)</field>
        <field name="model_id" ref="model_llm_scheduled_task_log"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_llm_task_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
</odoo>
