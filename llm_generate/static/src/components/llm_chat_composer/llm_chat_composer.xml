<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-inherit="llm_thread.LLMChatComposer" t-inherit-mode="extension" owl="1">
        <xpath expr="//div[hasclass('o_LLMChatComposer_container')]" position="attributes">
            <attribute name="t-if">shouldShowStandardComposer</attribute>
        </xpath>
        <!--
            No sustituir el contenedor completo: llm_thread ya incluye adjuntos y nota de voz.
            Solo añadimos el formulario de generación de medios debajo cuando aplique.
        -->
        <xpath expr="//div[hasclass('o_LLMChatComposer')]" position="inside">
            <t t-if="isMediaGenerationModel">
                <div
          class="o_LLMChatComposer_mediaFormContainer mx-auto mt-3 w-100"
          style="max-width: 1200px;"
        >
                    <div class="card border shadow-sm">
                        <div
              class="card-header bg-light d-flex justify-content-between align-items-center py-2"
            >
                            <h6 class="m-0 d-flex align-items-center">
                                <i class="fa fa-image mr-2 text-primary" />
                                <span>Generación de medios</span>
                            </h6>
                        </div>
                        <div class="card-body p-0">
                            <LLMMediaForm model="thread" />
                        </div>
                    </div>
                </div>
            </t>
        </xpath>
    </t>
</templates>
