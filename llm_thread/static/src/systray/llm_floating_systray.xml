<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="llm_thread.LLMFloatingSystrayMenuBody" owl="1">
        <div class="o_llm_floating_systray_head border-bottom p-2">
            <input
                type="search"
                class="form-control form-control-sm"
                t-att-placeholder="env._t('Buscar por título…')"
                t-att-value="props.systray.state.search"
                t-on-input="props.systray.onSearchInput"
            />
            <button
                type="button"
                class="btn btn-sm btn-link w-100 mt-1 text-start"
                t-on-click="onClickNewChat"
            >
                <i class="fa fa-plus me-1"/> <t t-esc="env._t('Nuevo chat')"/>
            </button>
        </div>
        <div class="o_llm_floating_systray_list overflow-auto flex-grow-1 min-h-0">
            <t t-if="props.systray.state.loadingThreads">
                <div class="p-3 text-muted text-center">
                    <i class="fa fa-circle-o-notch fa-spin me-1"/>
                    <t t-esc="env._t('Cargando…')"/>
                </div>
            </t>
            <t t-elif="props.systray.state.searchingRemote">
                <div class="p-3 text-muted text-center small">
                    <i class="fa fa-circle-o-notch fa-spin me-1"/>
                    <t t-esc="env._t('Buscando…')"/>
                </div>
            </t>
            <t t-elif="!props.systray.displayedThreads.length">
                <div class="p-3 text-muted small text-center">
                    <t t-esc="env._t('No hay conversaciones.')"/>
                </div>
            </t>
            <t t-else="">
                <t t-foreach="props.systray.displayedThreads" t-as="th" t-key="th.id">
                    <div
                        class="dropdown-item o_llm_floating_systray_thread px-3 py-2 cursor-pointer"
                        role="menuitem"
                        t-att-data-thread-id="th.id"
                        t-on-click="onClickThreadRow"
                    >
                        <div class="text-truncate fw-bold" t-esc="th.name"/>
                        <div class="small text-muted" t-if="th.write_date">
                            <t t-esc="th.write_date"/>
                        </div>
                    </div>
                </t>
                <t t-if="props.systray.state.hasMoreBrowse and !props.systray.state.searchMode">
                    <div class="border-top p-2">
                        <button
                            type="button"
                            class="btn btn-sm btn-outline-primary w-100"
                            t-att-disabled="props.systray.state.loadingMore"
                            t-on-click="onClickLoadMore"
                        >
                            <t t-if="props.systray.state.loadingMore">
                                <i class="fa fa-circle-o-notch fa-spin me-1"/>
                            </t>
                            <t t-esc="env._t('Cargar más')"/>
                        </button>
                    </div>
                </t>
            </t>
        </div>
    </t>

    <t t-name="llm_thread.LLMFloatingSystray" owl="1">
        <t t-if="state.showSystray">
            <div class="o_llm_floating_systray_wrap">
            <div class="o_llm_floating_systray_inner d-flex align-items-center">
                <Dropdown t-props="dropdownSystrayProps">
                    <t t-set-slot="toggler">
                        <i
                            class="fa fa-lg fa-magic"
                            role="img"
                            t-att-aria-label="env._t('Chat IA flotante')"
                            t-att-title="env._t('Chat IA flotante')"
                        />
                    </t>
                    <LLMFloatingSystrayMenuBody t-props="menuBodyProps"/>
                </Dropdown>
            </div>

            <t t-if="canShowFloatingPanel">
                <div
                    class="o_llm_floating_panel d-flex flex-column shadow"
                    t-att-class="{'o_llm_floating_panel--minimized': state.panelMinimized}"
                >
                    <div
                        class="o_llm_floating_panel_header d-flex align-items-center flex-shrink-0 px-2 py-1"
                        t-on-click="onClickFloatingHeaderBar"
                    >
                        <span
                            class="text-truncate flex-grow-1 fw-bold small"
                            t-esc="floatingPanelTitle"
                            t-att-title="floatingPanelTitle"
                        />
                        <div class="btn-group btn-group-sm" t-on-click.stop="noop">
                            <t t-if="!state.panelMinimized">
                            <button
                                type="button"
                                class="btn btn-light border-0"
                                t-att-title="env._t('Adjuntar HTML de la vista activa')"
                                t-on-click="onClickAttachActiveViewHtml"
                            >
                                <i class="fa fa-code"/>
                            </button>
                            <button
                                type="button"
                                class="btn btn-light border-0"
                                t-att-title="env._t('Abrir chat completo')"
                                t-on-click="onClickFullChat"
                            >
                                <i class="fa fa-external-link"/>
                            </button>
                            </t>
                            <button
                                t-if="!state.panelMinimized"
                                type="button"
                                class="btn btn-light border-0"
                                t-att-title="env._t('Minimizar')"
                                t-on-click="onClickMinimizePanel"
                            >
                                <i class="fa fa-minus"/>
                            </button>
                            <button
                                t-if="state.panelMinimized"
                                type="button"
                                class="btn btn-light border-0"
                                t-att-title="env._t('Restaurar conversación')"
                                t-on-click="onClickRestorePanel"
                            >
                                <i class="fa fa-expand"/>
                            </button>
                            <button
                                type="button"
                                class="btn btn-light border-0"
                                t-att-title="env._t('Cerrar panel')"
                                t-on-click="onClosePanel"
                            >
                                <i class="fa fa-times"/>
                            </button>
                        </div>
                    </div>
                    <div t-if="!state.panelMinimized" class="o_llm_floating_panel_body flex-grow-1 min-h-0 position-relative">
                        <t t-if="state.initializing">
                            <div class="o_llm_floating_panel_loading d-flex align-items-center justify-content-center h-100">
                                <i class="fa fa-circle-o-notch fa-spin fa-2x text-muted"/>
                            </div>
                        </t>
                        <t t-elif="messaging and messaging.llmChat and messaging.llmChat.llmChatView and messaging.isInitialized">
                            <LLMChat record="messaging.llmChat.llmChatView"/>
                        </t>
                    </div>
                </div>
            </t>
            </div>
        </t>
    </t>
</templates>
