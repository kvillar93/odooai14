<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t
    t-name="llm_thread.Chatter"
    t-inherit="mail.Chatter"
    t-inherit-mode="extension"
    owl="1"
  >
        <xpath expr="//div[hasclass('o_Chatter')]" position="attributes">
            <attribute name="class">o_Chatter d-flex flex-column</attribute>
        </xpath>

        <xpath expr="//div[hasclass('o_Chatter_scrollPanel')]" position="before">
            <t t-if="chatter.is_chatting_with_llm and chatter.messaging and chatter.messaging.llmChat and chatter.messaging.llmChat.llmChatView">
                <LLMChat record="chatter.messaging.llmChat.llmChatView" isChatterEmbedded="true" />
            </t>
        </xpath>

        <xpath expr="//div[hasclass('o_Chatter_scrollPanel')]" position="attributes">
            <attribute name="t-if">!chatter.is_chatting_with_llm</attribute>
        </xpath>
    </t>
</templates>
