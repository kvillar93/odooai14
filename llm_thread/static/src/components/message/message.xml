<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <t t-name="llm_thread.Message.AssistantContent" owl="1">
        <div class="o_Message_prettyBody" t-ref="prettyBody" t-raw="message.prettyBody or message.body or ''" />
        <t t-if="message.toolCalls and message.toolCalls.length > 0">
            <details class="o_llm_tool_calls o_llm_tool_calls--subtle mt-2 small text-muted border-top pt-1">
                <summary class="cursor-pointer user-select-none">
                    <strong>Herramientas solicitadas</strong>
                    <span class="text-muted"> (clic para ver)</span>
                </summary>
                <div class="mt-2">
                    <t t-foreach="message.toolCalls" t-as="toolCall" t-key="toolCall.id">
                        <span
                            class="badge bg-light text-dark border mr-1 mb-1"
                            t-att-title="toolCall.function and toolCall.function.arguments and ('ID: ' + toolCall.id + '\nArgs: ' + toolCall.function.arguments) or ''"
                        >
                            <i class="fa fa-cog mr-1" aria-hidden="true" />
                            <t t-esc="toolCall.function and toolCall.function.name or ''" />
                        </span>
                    </t>
                </div>
            </details>
        </t>
        <div class="o_llm_message_vote mt-2 border-top pt-2" t-on-click.stop="">
            <span
                class="o_Message_command fa fa-lg mr-2"
                role="button"
                tabindex="0"
                title="Voto positivo"
                t-att-class="{'fa-thumbs-up text-primary': message.user_vote === 1, 'fa-thumbs-o-up': message.user_vote !== 1}"
                t-on-click="_onClickLlmThumbUp"
            />
            <span
                class="o_Message_command fa fa-lg"
                role="button"
                tabindex="0"
                title="Voto negativo"
                t-att-class="{'fa-thumbs-down text-primary': message.user_vote === -1, 'fa-thumbs-o-down': message.user_vote !== -1}"
                t-on-click="_onClickLlmThumbDown"
            />
        </div>
    </t>

    <t t-name="llm_thread.Message.ToolResultContent" owl="1">
        <div class="o_Message_prettyBody o_llm_tool_result">
            <p class="d-none mb-0" t-ref="prettyBody" />
            <div class="o_llm_tool_card">
                <div class="o_llm_tool_card_head">
                    <div
                        class="o_llm_tool_card_icon"
                        t-att-class="message.toolCallResultIsError ? 'bg-light text-danger' : ''"
                    >
                        <i
                            class="fa"
                            t-att-class="message.toolCallResultIsError ? 'fa-exclamation-circle' : 'fa-check'"
                            aria-hidden="true"
                        />
                    </div>
                    <div class="o_llm_tool_card_title text-truncate">
                        <t t-esc="message.toolName or (message.toolCallDefinitionFormatted and message.toolCallDefinitionFormatted.function and message.toolCallDefinitionFormatted.function.name) or 'Herramienta'" />
                        <div class="o_llm_tool_card_meta">
                            Resultado
                            <t t-if="message.toolCallId">
                                · ID <t t-esc="message.toolCallId" />
                            </t>
                        </div>
                    </div>
                    <div class="o_llm_tool_card_actions">
                        <button
                            type="button"
                            class="btn btn-sm btn-outline-secondary"
                            title="Copiar JSON completo"
                            t-on-click="_onClickCopyLlmToolResult"
                        >
                            <i class="fa fa-copy" />
                        </button>
                    </div>
                </div>
                <div class="o_llm_tool_card_body">
                    <p class="o_llm_tool_card_hint">
                        <t t-if="message.toolCallResultIsError">
                            Se produjo un error al ejecutar la herramienta. Puedes ver el detalle técnico abajo.
                        </t>
                        <t t-else="">
                            La herramienta terminó correctamente. El detalle técnico (JSON) está oculto por defecto; ábrelo solo si lo necesitas.
                        </t>
                    </p>
                    <div class="o_llm_tool_raw">
                        <details class="mb-1">
                            <summary>Argumentos enviados al motor</summary>
                            <pre class="bg-100 p-2 rounded small mt-1 mb-0 border"><code
                                t-esc="message.toolCallDefinitionFormatted and message.toolCallDefinitionFormatted.function and message.toolCallDefinitionFormatted.function.arguments or '{}'"
                            /></pre>
                        </details>
                        <details>
                            <summary>Respuesta técnica (raw)</summary>
                            <t t-if="message.toolCallResultIsError">
                                <pre
                                    class="bg-light border border-danger text-danger p-2 rounded small mt-1 mb-0"
                                ><code
                                    t-esc="message.toolCallResultData and message.toolCallResultData.error or 'Error desconocido'"
                                /></pre>
                            </t>
                            <t t-else="">
                                <pre
                                    class="bg-100 border p-2 rounded small mt-1 mb-0 o_llm_tool_result_pre"
                                ><code t-esc="message.toolCallResultFormatted" /></pre>
                            </t>
                        </details>
                    </div>
                </div>
            </div>
        </div>
    </t>

    <t t-name="llm_thread.Message.DefaultContent" owl="1">
        <div class="o_Message_prettyBody" t-ref="prettyBody" t-raw="message.prettyBody or message.body or ''" />
        <t t-if="message.subtype_description and !message.isBodyEqualSubtypeDescription">
            <p t-esc="message.subtype_description" class="mb-0" />
        </t>
        <t t-if="trackingValues.length > 0">
            <ul class="o_Message_trackingValues mb-0 pl-4">
                <t t-foreach="trackingValues" t-as="value" t-key="value.id">
                    <li>
                        <div class="o_Message_trackingValue" role="group">
                            <div class="o_Message_trackingValueFieldName o_Message_trackingValueItem" t-esc="value.changed_field"/>
                            <t t-if="value.old_value">
                                <div class="o_Message_trackingValueOldValue o_Message_trackingValueItem" t-esc="value.old_value"/>
                            </t>
                            <div class="o_Message_trackingValueSeparator o_Message_trackingValueItem fa fa-long-arrow-right" title="Changed" role="img"/>
                            <t t-if="value.new_value">
                                <div class="o_Message_trackingValueNewValue o_Message_trackingValueItem" t-esc="value.new_value"/>
                            </t>
                        </div>
                    </li>
                </t>
            </ul>
        </t>
    </t>

    <t
        t-name="llm_thread.Message"
        t-inherit="mail.Message"
        t-inherit-mode="extension"
        owl="1"
    >
        <xpath expr="//div[hasclass('o_Message_content')]" position="replace">
            <div
                class="o_Message_content position-relative text-break"
                t-att-class="{'opacity-75': props.isSquashed}"
                t-ref="content"
            >
                <t t-if="message.llmRole === 'assistant'">
                    <t t-call="llm_thread.Message.AssistantContent" />
                </t>
                <t t-elif="message.llmRole === 'tool'">
                    <t t-call="llm_thread.Message.ToolResultContent" />
                </t>
                <t t-else="">
                    <t t-call="llm_thread.Message.DefaultContent" />
                </t>
                <div class="o_Message_linkPreviews" />
            </div>
        </xpath>
    </t>

</templates>
