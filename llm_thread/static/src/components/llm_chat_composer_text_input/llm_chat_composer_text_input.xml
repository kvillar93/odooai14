<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="llm_thread.LLMChatComposerTextInput" owl="1">
        <t t-if="composerView">
            <div
        class="o_LLMChatComposerTextInput o_LLMChatComposerTextInput--pill position-relative w-100 min-w-0"
        t-on-paste="composerView.onPasteTextInput"
        t-ref="root"
      >
                <textarea
          class="o_LLMChatComposerTextInput_textarea o_LLMChatComposerTextInput_textarea--pill form-control shadow-none"
          rows="1"
          t-att-placeholder="composerView.composer.placeholderLLMChat"
          t-on-click="composerView.onClickTextarea"
          t-on-focusin="composerView.onFocusinTextarea"
          t-on-focusout="composerView.onFocusoutTextarea"
          t-on-keydown="_onKeydown"
          t-on-input="_onInput"
          t-ref="textarea"
        />
                <!--
                    from ComposerTextInput for `mail` module: This is an invisible textarea used to compute the composer
                     height based on the text content. We need it to downsize
                     the textarea properly without flicker.
                -->
                <textarea
          class="o_LLMChatComposerTextInput_mirrored o_ComposerTextInput_mirroredTextarea o_ComposerTextInput_textareaStyle position-absolute border-0 overflow-hidden opacity-0"
          t-att-class="{ 'o-composer-is-compact': composerView.isCompact }"
          t-esc="composerView.composer.textInputContent"
          t-ref="mirroredTextarea"
          disabled="1"
        />
            </div>
        </t>
    </t>
</templates>
