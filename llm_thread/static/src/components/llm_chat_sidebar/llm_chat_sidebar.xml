<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="llm_thread.LLMChatSidebar" owl="1">
        <!-- Backdrop (mobile only) -->
        <t t-if="llmChatView.isSmall">
            <div
                class="o_LLMChatSidebar_backdrop"
                t-att-class="{ 'o-visible': llmChatView.isThreadListVisible }"
                t-on-click="_onBackdropClick"
            />
        </t>

        <!-- Sidebar -->
        <div
            class="o_LLMChatSidebar o_LLMChatSidebar--modern o_DiscussSidebar d-flex flex-column flex-shrink-0 h-100 border-end"
            t-att-class="{
                'o-mobile': llmChatView.isSmall,
                'o-visible': !llmChatView.isSmall || llmChatView.isThreadListVisible,
                'overflow-auto': !llmChatView.isSidebarCollapsed
            }"
            t-att-style="!llmChatView.isSmall ? (llmChatView.isSidebarCollapsed ? 'width: 48px;' : 'width: 280px;') : ''"
        >
            <!-- Desktop: Collapse/Expand Header -->
            <t t-if="!llmChatView.isSmall">
                <div
                    class="d-flex align-items-center border-bottom"
                    t-att-class="llmChatView.isSidebarCollapsed ? 'justify-content-center px-2 py-3' : 'justify-content-between p-3'"
                >
                    <!-- Expanded: Header content + collapse button -->
                    <t t-if="!llmChatView.isSidebarCollapsed">
                        <h6 class="mb-0 text-muted">Conversations</h6>
                        <button
                            class="btn btn-secondary btn-sm px-2 py-1"
                            t-on-click="_onClickToggleSidebar"
                            title="Collapse sidebar"
                        >
                            <i class="oi oi-panel-right" />
                        </button>
                    </t>

                    <!-- Collapsed: Centered expand button -->
                    <t t-else="">
                        <button
                            class="btn btn-secondary btn-sm px-2 py-1"
                            t-on-click="_onClickToggleSidebar"
                            title="Expand sidebar"
                        >
                            <i class="oi oi-panel-right" style="transform: rotate(180deg);" />
                        </button>
                    </t>
                </div>

                <!-- Desktop: New Chat Button (only when expanded) -->
                <div t-if="!llmChatView.isSidebarCollapsed" class="d-flex justify-content-center p-3">
                    <button
                        class="btn btn-primary rounded w-100"
                        t-on-click="_onClickNewChat"
                    >
                        <i class="fa fa-plus me-2" />
                        <span>New Chat</span>
                    </button>
                </div>

                <!-- Desktop: Thread List (only when expanded) -->
                <div t-if="!llmChatView.isSidebarCollapsed" class="flex-grow-1 overflow-auto">
                    <LLMChatThreadList record="llmChatView" />
                </div>
            </t>

            <!-- Mobile: Simple layout -->
            <t t-else="">
                <div class="d-flex align-items-center justify-content-between border-bottom p-3">
                    <h6 class="mb-0 text-muted">Conversations</h6>
                </div>

                <!-- Mobile: New Chat Button -->
                <div class="d-flex justify-content-center p-3">
                    <button
                        class="btn btn-primary rounded w-100"
                        t-on-click="_onClickNewChat"
                    >
                        <i class="fa fa-plus me-2" />
                        <span>New Chat</span>
                    </button>
                </div>

                <!-- Mobile: Thread List -->
                <div class="flex-grow-1 overflow-auto">
                    <LLMChatThreadList record="llmChatView" />
                </div>
            </t>
        </div>
    </t>
</templates>
