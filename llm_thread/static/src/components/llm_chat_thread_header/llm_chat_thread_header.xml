<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="llm_thread.LLMChatThreadHeader" owl="1">
        <div
      class="o_LLMChatThread_header_modern o_ThreadViewTopbar d-flex flex-shrink-0 w-100 px-3 bg-100 border-bottom align-items-center"
      t-ref="root"
    >
            <!-- Lista de hilos: hamburguesa en móvil y siempre en popup flotante -->
            <button
        t-if="showThreadListHamburger"
        class="o_ThreadViewTopbar_button btn px-2 border-none rounded shadow-none mr-2 flex-shrink-0"
        t-on-click="_onToggleThreadList"
        t-att-title="env._t('Mostrar u ocultar conversaciones')"
        type="button"
      >
                <i
          class="fa fa-lg fa-bars text-700"
          role="img"
          t-att-aria-label="env._t('Mostrar u ocultar conversaciones')"
        />
            </button>

            <!-- Nombre del hilo (oculto en popup flotante: ya se muestra en la cabecera morada) -->
            <div
        t-if="!useCompactHeaderIcons"
        class="o_ThreadViewTopbar_title d-flex flex-grow-1 align-items-center min-w-0 mr-2"
      >
                <t t-if="!llmChatThreadHeaderView.isEditingName || isSmall">
                    <div
            class="o_ThreadViewTopbar_threadName o_ThreadViewTopbar_editableItem lead flex-shrink-1 px-1 border text-truncate font-weight-bold"
            t-att-title="displayThreadName"
            t-on-click="llmChatThreadHeaderView.onClickTopbarThreadName"
            t-attf-class="{{ isSmall ? 'border-0' : 'border-light' }}"
            style="cursor: pointer;"
          >
                        <t t-esc="displayThreadName" />
                    </div>
                </t>
                <t t-if="llmChatThreadHeaderView.isEditingName and !isSmall">
                    <input
            class="o_ThreadViewTopbar_threadNameInput form-control lead font-weight-bold o_input_tooltip flex-shrink-1"
            type="text"
            autofocus="autofocus"
            t-att-value="llmChatThreadHeaderView.pendingName"
            t-on-input="onInputThreadNameInput"
            t-on-keydown="onKeyDownThreadNameInput"
            t-ref="threadNameInput"
            title="Press Enter to save, Esc to cancel"
            data-toggle="tooltip"
            data-placement="bottom"
          />
                    <button
            class="btn btn-sm btn-primary ml-1"
            t-on-click="llmChatThreadHeaderView.saveThreadName"
            title="Save"
          >
                        <i class="fa fa-check" />
                    </button>
                    <button
            class="btn btn-sm btn-secondary ml-1"
            t-on-click="llmChatThreadHeaderView.discardThreadNameEdition"
            title="Cancel"
          >
                        <i class="fa fa-times" />
                    </button>
                </t>
            </div>

            <!-- Enlace a registro (+ Enlace): oculto en popup flotante -->
            <div t-if="!useCompactHeaderIcons" class="mr-2 flex-shrink-0">
                <LLMChatThreadRelatedRecord thread="thread" />
            </div>

            <!-- Dropdowns (Desktop) -->
            <div
        t-if="thread and !isSmall and !thread.hideThreadSettings and llmChat and useCompactHeaderIcons"
        class="o_ThreadDropdowns o_LLMChatThread_header_dropdowns--compact d-flex align-items-center flex-shrink-0 o_llm_flex_gap_sm ml-auto"
      >
                <div class="dropdown">
                    <button
            class="btn btn-sm btn-outline-secondary dropdown-toggle o-no-caret o_LLMChat_headerIconBtn d-flex align-items-center justify-content-center"
            type="button"
            data-toggle="dropdown"
            aria-expanded="false"
            t-att-title="compactProviderTitle"
            t-att-aria-label="compactProviderTitle"
          >
                        <i class="fa fa-cloud text-body"/>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-right">
                        <t
              t-foreach="llmProviders"
              t-as="provider"
              t-key="provider.id"
            >
                            <li>
                                <a
                  class="dropdown-item text-truncate"
                  href="#"
                  t-on-click.prevent="() => this.onSelectProvider(provider)"
                  t-att-title="provider.name"
                  t-attf-class="{{ llmChatThreadHeaderView.selectedProviderId === provider.id ? 'active' : '' }}"
                >
                                    <t t-esc="provider.name" />
                                </a>
                            </li>
                        </t>
                    </ul>
                </div>
                <div class="dropdown" t-ref="modelDropdown">
                    <button
            class="btn btn-sm btn-outline-secondary dropdown-toggle o-no-caret o_LLMChat_headerIconBtn d-flex align-items-center justify-content-center"
            type="button"
            data-toggle="dropdown"
            aria-expanded="false"
            t-att-disabled="!llmChatThreadHeaderView.selectedProviderId"
            t-att-title="compactModelTitle"
            t-att-aria-label="compactModelTitle"
          >
                        <i class="fa fa-android text-body" aria-hidden="true"/>
                    </button>
                    <div
            class="dropdown-menu dropdown-menu-right p-0"
           
            style="min-width: 250px; max-height: 300px; overflow-y: auto;"
          >
                        <div class="p-2 border-bottom">
                             <input
                type="text"
                class="form-control form-control-sm"
                placeholder="Buscar asistentes..."
                t-att-value="state.modelSearchQuery"
                t-on-input="onModelSearchInput"
                t-on-click="_preventDropdownClose"
                t-ref="modelSearchInput"
                aria-label="Buscar asistentes"
              />
                         </div>
                        <ul class="list-unstyled mb-0">
                            <t t-if="filteredModels.length > 0">
                                <t
                  t-foreach="filteredModels"
                  t-as="model"
                  t-key="model.id"
                >
                                    <li>
                                        <a
                      href="#"
                      class="dropdown-item text-truncate d-block"
                      t-on-click.prevent="() => onSelectModel(model)"
                      t-att-title="model.name"
                      t-attf-class="{{ llmChatThreadHeaderView.selectedModelId === model.id ? 'active' : '' }}"
                    >
                                            <t t-esc="model.name" />
                                        </a>
                                    </li>
                                </t>
                            </t>
                            <t t-else="">
                                <li
                  class="dropdown-item text-muted disabled"
                >No hay asistentes<t t-if="state.modelSearchQuery"> para «<t
                      t-esc="state.modelSearchQuery"
                    />»</t>.</li>
                            </t>
                         </ul>
                    </div>
                </div>
                <div class="dropdown">
                    <button
            class="btn btn-sm btn-outline-secondary dropdown-toggle o-no-caret o_LLMChat_headerIconBtn o_LLMChat_headerIconBtn--withNotify d-flex align-items-center justify-content-center position-relative"
            type="button"
            data-toggle="dropdown"
            aria-expanded="false"
            t-att-title="compactToolsTitle"
            t-att-aria-label="compactToolsTitle"
          >
                        <i class="fa fa-wrench text-body"/>
                        <t t-if="thread.selectedToolIds and thread.selectedToolIds.length > 0">
                            <span class="o_LLMChat_toolNotifyBadge">
                                <t t-esc="thread.selectedToolIds.length"/>
                            </span>
                        </t>
                    </button>
                    <div
            class="dropdown-menu dropdown-menu-right p-2"
           
            style="min-width: 200px;"
          >
                        <h6
              class="dropdown-header px-2 py-1"
            >Available Tools</h6>
                        <div style="max-height: 250px; overflow-y: auto;">
                            <t
                t-if="llmToolsList.length > 0"
              >
                                <t
                  t-foreach="llmToolsList"
                  t-as="tool"
                  t-key="tool.id"
                >
                                    <div
                    class="form-check dropdown-item mb-0"
                  >
                                        <input
                      type="checkbox"
                      class="form-check-input"
                      t-att-id="'tool-checkbox-' + tool.id"
                      t-att-value="tool.id"
                      t-att-checked="thread.selectedToolIds and thread.selectedToolIds.includes(tool.id)"
                      t-on-change="(ev) => onToolSelectChange(ev, tool)"
                    />
                                        <label
                      class="form-check-label"
                      t-att-for="'tool-checkbox-' + tool.id"
                    >
                                            <t t-esc="tool.name" />
                                        </label>
                                    </div>
                                </t>
                            </t>
                            <t t-else="">
                                <div
                  class="dropdown-item text-muted disabled"
                >No tools available.</div>
                            </t>
                        </div>
                    </div>
                </div>
            </div>

            <div
        t-if="thread and !isSmall and !thread.hideThreadSettings and llmChat and !useCompactHeaderIcons"
        class="o_ThreadDropdowns o_ThreadDropdowns--expanded d-flex align-items-center flex-shrink-0"
      >
                <!-- LLM Provider Dropdown -->
                <div class="dropdown">
                    <button
            class="btn btn-light dropdown-toggle d-flex align-items-center o_llm_flex_gap_sm"
            type="button"
            data-toggle="dropdown"
            aria-expanded="false"
            style="max-width: 180px;"
          >
                        <span class="text-truncate">
                            <t t-if="llmChatThreadHeaderView.selectedProvider">
                                <t
                  t-esc="llmChatThreadHeaderView.selectedProvider.name"
                />
                            </t>
                            <t t-else="">
                                Select Provider
                            </t>
                        </span>
                    </button>
                    <ul class="dropdown-menu">
                        <t
              t-foreach="llmProviders"
              t-as="provider"
              t-key="provider.id"
            >
                            <li>
                                <a
                  class="dropdown-item text-truncate"
                  href="#"
                  t-on-click.prevent="() => this.onSelectProvider(provider)"
                  t-att-title="provider.name"
                  t-attf-class="{{ llmChatThreadHeaderView.selectedProviderId === provider.id ? 'active' : '' }}"
                >
                                    <t t-esc="provider.name" />
                                </a>
                            </li>
                        </t>
                    </ul>
                </div>

                <!-- LLM Model Searchable Dropdown -->
                <div class="dropdown ml-2" t-ref="modelDropdown">
                    <button
            class="btn btn-light dropdown-toggle d-flex align-items-center o_llm_flex_gap_sm"
            type="button"
            data-toggle="dropdown"
            aria-expanded="false"
            style="max-width: 180px;"
            t-att-disabled="!llmChatThreadHeaderView.selectedProviderId"
            title="{{ llmChatThreadHeaderView.selectedProviderId ? (llmChatThreadHeaderView.selectedModel ? llmChatThreadHeaderView.selectedModel.name : 'Select Model') : 'Select a provider first'}}"
          >
                        <span class="text-truncate">
                            <t t-if="llmChatThreadHeaderView.selectedModel">
                                <t
                  t-esc="llmChatThreadHeaderView.selectedModel.name"
                />
                            </t>
                            <t t-else="">
                                Select Model
                            </t>
                        </span>
                    </button>
                    <!-- Add to keep dropdown open -->
                    <div
            class="dropdown-menu p-0"
           
            style="min-width: 250px; max-height: 300px; overflow-y: auto;"
          >
                         <!-- Search Input -->
                        <div class="p-2 border-bottom">
                             <input
                type="text"
                class="form-control form-control-sm"
                placeholder="Search models..."
                t-att-value="state.modelSearchQuery"
                t-on-input="onModelSearchInput"
                t-on-click="_preventDropdownClose"
                t-ref="modelSearchInput"
                aria-label="Search models"
              />
                         </div>
                        <!-- Filtered Model List -->
                        <ul class="list-unstyled mb-0">
                            <t t-if="filteredModels.length > 0">
                                <t
                  t-foreach="filteredModels"
                  t-as="model"
                  t-key="model.id"
                >
                                    <li>
                                        <a
                      href="#"
                      class="dropdown-item text-truncate d-block"
                      t-on-click.prevent="() => onSelectModel(model)"
                      t-att-title="model.name"
                      t-attf-class="{{ llmChatThreadHeaderView.selectedModelId === model.id ? 'active' : '' }}"
                    >
                                            <t t-esc="model.name" />
                                        </a>
                                    </li>
                                </t>
                            </t>
                            <t t-else="">
                                <li
                  class="dropdown-item text-muted disabled"
                >No models found<t t-if="state.modelSearchQuery"> for '<t
                      t-esc="state.modelSearchQuery"
                    />'</t>.</li>
                            </t>
                         </ul>
                    </div>
                </div>

                <!-- Tools Dropdown -->
                <div class="dropdown ml-2">
                    <button
            class="btn btn-light dropdown-toggle d-flex align-items-center o_llm_flex_gap_sm"
            type="button"
            data-toggle="dropdown"
            aria-expanded="false"
            style="max-width: 120px;"
            title="Select Tools"
          >
                        Tools
                        <t
              t-if="thread.selectedToolIds and thread.selectedToolIds.length > 0"
            >
                            <span class="badge bg-secondary ml-1">
                                <t t-esc="thread.selectedToolIds.length" />
                            </span>
                        </t>
                    </button>
                    <!-- Add to keep dropdown open -->
                    <div
            class="dropdown-menu p-2"
           
            style="min-width: 200px;"
          >
                        <h6
              class="dropdown-header px-2 py-1"
            >Available Tools</h6>
                        <div style="max-height: 250px; overflow-y: auto;">
                            <t
                t-if="llmToolsList.length > 0"
              >
                                <t
                  t-foreach="llmToolsList"
                  t-as="tool"
                  t-key="tool.id"
                >
                                    <div
                    class="form-check dropdown-item mb-0"
                  > <!-- Wrap in dropdown-item for hover effect -->
                                        <input
                      type="checkbox"
                      class="form-check-input"
                      t-att-id="'tool-checkbox-' + tool.id"
                      t-att-value="tool.id"
                      t-att-checked="thread.selectedToolIds and thread.selectedToolIds.includes(tool.id)"
                      t-on-change="(ev) => onToolSelectChange(ev, tool)"
                    />
                                        <label
                      class="form-check-label"
                      t-att-for="'tool-checkbox-' + tool.id"
                    >
                                            <t t-esc="tool.name" />
                                        </label>
                                    </div>
                                </t>
                            </t>
                            <t t-else="">
                                <div
                  class="dropdown-item text-muted disabled"
                >No tools available.</div>
                            </t>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Settings Button (Mobile) -->
            <button
        class="o_ThreadViewTopbar_button btn px-2 border-none rounded shadow-none ml-auto flex-shrink-0"
        t-if="isSmall"
        t-on-click="llmChatThreadHeaderView.openThreadSettings"
        title="Settings"
      >
                <i class="fa fa-lg fa-gear text-700" />
            </button>
        </div>
    </t>
</templates>
