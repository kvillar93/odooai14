<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="llm_thread.LLMChatComposer" owl="1">
        <div class="o_LLMChatComposer o_LLMChatComposer--modern w-100" t-if="composer">
            <FileUploader
                attachmentLocalIds="composer.attachments.map(attachment => attachment.localId)"
                newAttachmentExtraData="newAttachmentExtraData"
                t-ref="fileUploader"
            />
            <div class="o_LLMChatComposer_container d-flex flex-column mx-auto w-100">
                <t t-if="composer.attachments.length > 0">
                    <AttachmentList
                        className="'o_Composer_attachmentList o_LLMChatComposer_attachmentList flex-grow-1'"
                        areAttachmentsEditable="true"
                        attachmentsDetailsMode="'auto'"
                        attachmentsImageSize="'small'"
                        attachmentLocalIds="composer.attachments.map(attachment => attachment.localId)"
                        showAttachmentsExtensions="true"
                        showAttachmentsFilenames="true"
                    />
                </t>
                <div class="o_LLMChatComposer_pill w-100">
                    <div class="o_LLMChatComposer_pillBody d-flex flex-nowrap align-items-center w-100 min-w-0">
                        <button
                            class="o_LLMChatComposer_iconBtn o_LLMChatComposer_toolBtn o_LLMChatComposer_attachBtn btn p-0 border-0 flex-shrink-0"
                            type="button"
                            title="Adjuntar archivo"
                            aria-label="Adjuntar archivo"
                            t-on-click="_onClickAddAttachment"
                        >
                            <i class="fa fa-paperclip" />
                        </button>
                        <div class="o_LLMChatComposer_textCell flex-grow-1 min-w-0">
                            <LLMChatComposerTextInput
                                composerLocalId="composerLocalId"
                                hasMentionSuggestionsBelowPosition="false"
                                isCompact="true"
                                sendShortcuts="textInputSendShortcuts"
                            />
                        </div>
                        <div class="o_LLMChatComposer_actionsEnd d-flex align-items-center flex-shrink-0">
                            <button
                                t-if="state.hasVoiceAPI"
                                class="o_LLMChatComposer_iconBtn o_LLMChatComposer_toolBtn btn p-0 border-0"
                                t-att-class="state.isRecording ? 'o_LLMChatComposer_iconBtn--recording' : ''"
                                type="button"
                                title="Nota de voz"
                                aria-label="Nota de voz"
                                t-on-click="onClickVoiceRecording"
                            >
                                <i
                                    class="fa"
                                    t-att-class="state.isRecording ? 'fa-stop' : 'fa-microphone'"
                                />
                            </button>
                            <t t-if="!isStreaming">
                                <button
                                    class="o_LLMChatComposer_sendBtn o_Composer_actionButton o_Composer_button o_Composer_buttonSend btn o-last d-inline-flex align-items-center justify-content-center border-0"
                                    t-on-click="_onClickSend"
                                    t-att-disabled="isDisabled"
                                    type="button"
                                    title="Enviar"
                                    aria-label="Enviar"
                                >
                                    <i class="fa fa-arrow-up" />
                                </button>
                            </t>
                            <t t-if="isStreaming">
                                <button
                                    class="o_LLMChatComposer_sendBtn o_LLMChatComposer_sendBtn--stop o_Composer_actionButton o_Composer_button o_Composer_buttonStop btn o-last d-inline-flex align-items-center justify-content-center border-0"
                                    t-on-click="_onClickStop"
                                    type="button"
                                    title="Detener"
                                    aria-label="Detener"
                                >
                                    <i class="fa fa-stop" />
                                </button>
                            </t>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
