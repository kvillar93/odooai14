<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_llm_chat_window_menu_wizard_form" model="ir.ui.view">
        <field name="name">llm.chat.window.menu.wizard.form</field>
        <field name="model">llm.chat.window.menu.wizard</field>
        <field name="arch" type="xml">
            <form string="Crear entrada de menú">
                <group>
                    <field name="window_id" readonly="1" />
                    <field
                        name="parent_menu_id"
                        options="{'no_create': True}"
                    />
                    <field name="menu_name" placeholder="Mismo nombre que la ventana si se deja vacío" />
                    <field name="sequence" />
                </group>
                <footer>
                    <button
                        name="action_create_menu"
                        type="object"
                        string="Crear menú"
                        class="btn-primary"
                    />
                    <button string="Cancelar" special="cancel" class="btn-secondary" />
                </footer>
            </form>
        </field>
    </record>
</odoo>
