<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="llm_experience.LLMContextMeter" owl="1">
        <div
            class="o_llm_ctxMeter o_llm_ctxMeter--wrap flex-shrink-0 position-relative"
            t-ref="root"
        >
            <t t-if="state.loaded and state.selectorEnabled">
                <button
                    type="button"
                    class="o_llm_ctxMeter__trigger btn border-0 p-0 position-relative"
                    style="width:28px;height:28px;line-height:0;"
                    t-ref="trigger"
                    t-att-title="ctxTitle"
                    t-att-disabled="state.saving"
                    t-att-aria-expanded="ariaExpanded"
                    t-att-aria-haspopup="true"
                    t-att-aria-label="ariaLabel"
                    t-on-click="toggleMenu"
                >
                    <span
                        class="o_llm_ctxMeter__gauge"
                        aria-hidden="true"
                        style="position:relative;display:inline-block;width:28px;height:28px;"
                        t-att-title="ctxTitle"
                    >
                        <svg class="o_llm_ctxMeter__svg" viewBox="0 0 40 40" width="28" height="28" style="display:block;">
                            <circle
                                class="o_llm_ctxMeter__ring-bg"
                                cx="20"
                                cy="20"
                                r="16"
                                fill="none"
                                stroke-width="3"
                                stroke="rgba(0,0,0,0.1)"
                            />
                            <circle
                                t-att-class="ringFillClass"
                                cx="20"
                                cy="20"
                                r="16"
                                fill="none"
                                stroke-width="3"
                                stroke-linecap="round"
                                transform="rotate(-90 20 20)"
                                t-att-stroke-dasharray="gaugeDashArray"
                                t-att-stroke-dashoffset="gaugeDashOffset"
                            />
                        </svg>
                        <span class="o_llm_ctxMeter__abbr" t-esc="currentOption.abbr"/>
                    </span>
                </button>
                <div
                    t-if="state.menuOpen"
                    t-ref="menu"
                    class="o_llm_ctxMeter__menu shadow-sm bg-white border py-1"
                    role="menu"
                >
                    <t t-foreach="options" t-as="opt" t-key="opt.value">
                        <button
                            type="button"
                            class="o_llm_ctxMeter__item d-flex align-items-center py-2 px-2 w-100 border-0 bg-transparent text-start"
                            t-att-class="{'o_llm_ctxMeter__item--active': state.current === opt.value}"
                            role="menuitem"
                            t-att-data-mode="opt.value"
                            t-on-click="onPickMode"
                        >
                            <i t-att-class="'fa ' + opt.icon + ' o_llm_ctxMeter__itemIcon flex-shrink-0 mr-2'"/>
                            <span class="o_llm_ctxMeter__itemAbbr" t-esc="opt.abbr"/>
                            <span class="o_llm_ctxMeter__itemLabel text-truncate" t-esc="opt.label"/>
                        </button>
                    </t>
                </div>
            </t>
            <t t-if="state.loaded and !state.selectorEnabled">
                <div class="o_llm_ctxMeter__gaugeOnly position-relative" style="line-height:0;">
                    <span
                        class="o_llm_ctxMeter__gauge"
                        aria-hidden="true"
                        style="position:relative;display:inline-block;width:28px;height:28px;"
                        t-att-title="ctxTitle"
                    >
                        <svg class="o_llm_ctxMeter__svg" viewBox="0 0 40 40" width="28" height="28" style="display:block;">
                            <circle
                                class="o_llm_ctxMeter__ring-bg"
                                cx="20"
                                cy="20"
                                r="16"
                                fill="none"
                                stroke-width="3"
                                stroke="rgba(0,0,0,0.1)"
                            />
                            <circle
                                t-att-class="ringFillClass"
                                cx="20"
                                cy="20"
                                r="16"
                                fill="none"
                                stroke-width="3"
                                stroke-linecap="round"
                                transform="rotate(-90 20 20)"
                                t-att-stroke-dasharray="gaugeDashArray"
                                t-att-stroke-dashoffset="gaugeDashOffset"
                            />
                        </svg>
                    </span>
                </div>
            </t>
            <t t-if="!state.loaded">
                <span class="o_llm_ctxMeter__placeholder o_llm_ctxMeter__gauge" aria-hidden="true" style="position:relative;display:inline-block;width:28px;height:28px;">
                    <svg class="o_llm_ctxMeter__svg o_llm_ctxMeter__svg--muted" viewBox="0 0 40 40" width="28" height="28" style="display:block;opacity:0.45;">
                        <circle
                            class="o_llm_ctxMeter__ring-bg"
                            cx="20"
                            cy="20"
                            r="16"
                            fill="none"
                            stroke-width="3"
                            stroke="rgba(0,0,0,0.1)"
                        />
                    </svg>
                </span>
            </t>
        </div>
    </t>
</templates>
